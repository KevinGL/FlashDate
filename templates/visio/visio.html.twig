{% extends 'base.html.twig' %}

{% block title %}Hello VisioController!{% endblock %}

{% block body %}

<div class="flex flex-row w-full justify-around mt-20">
    
    <div class="flex flex-col w-4/5 h-auto items-center relative">
        <video id="receiver" class="w-full h-full bg-gray-800 rounded-lg" playsinline autoplay muted></video>

        <video id="emitter" class="w-[100px] h-[100px] bg-gray-800 rounded-lg absolute right-5 top-5" playsinline autoplay></video>

        <button id="start" class="mt-2 px-4 py-2 bg-blue-500 text-white rounded">Démarrer</button>
    </div>
    
</div>

<script src="{{ asset('visio/simplePeer.js') }}"></script>
<script src="{{ asset('visio/index.js') }}"></script>

{% endblock %}
