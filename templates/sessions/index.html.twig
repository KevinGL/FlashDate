{% extends 'base.html.twig' %}

{% block title %}Choisis ta prochaine session{% endblock %}

{% block body %}

<div class="flex flex-col items-center">
    <h1 class="text-4xl">Choisis ta prochaine session !</h1>

    <ul class="flex flex-wrap gap-5 mt-10 justify-center w-full">
        {% for session in sessions %}
            <li class="w-full sm:w-1/3 {{ session.isActive == 0 ? 'opacity-50' : '' }}">
                <div class="bg-white p-4 rounded-2xl shadow-lg border border-gray-100">
                    <img src="{{ session.img }}" class="w-full h-80 object-cover rounded-xl"/>
                    <h3 class="mt-4 text-xl font-semibold text-gray-800">Le {{ session.startAt | date('d/m/Y à H:i') }}</h3>
                    {% if "ROLE_ADMIN" in app.user.roles %}
                        <a href="{{ url('edit_session', {id: session.id}) }}">Modifier</a>
                    {% endif %}
                    <button class="mt-4 w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition">
                        Réserver
                    </button>
                </div>
            </li>
        {% endfor %}
    </ul>

    {% if "ROLE_ADMIN" in app.user.roles %}
        <button id="add">Ajouter les sessions des deux prochaines semaines</button>
    {% endif %}
</div>

{% block javascripts %}
    {{ importmap('app') }}
    <script type="module">
        import $ from 'jquery';
        $(document).ready(function() {
            //console.log('jQuery est bien chargé !');

            $("#add").click(() => {
                $.get("/sessions/add").then(() => {
                    location.reload();
                })
            });
        });
    </script>
{% endblock %}
{% endblock %}
