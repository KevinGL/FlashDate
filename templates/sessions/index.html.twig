{% extends 'base.html.twig' %}

{% block title %}Choisis ta prochaine session{% endblock %}

{% block body %}

<div class="flex flex-col items-center">
    <h1>Choisis ta prochaine session !</h1>

    <ul class="flex flex-col items-center gap-5 mt-10">
        {% for session in sessions %}
            <li>
                <div class="flex flex-col items-center">
                    <h3>Le {{ session.startAt | date }}</h3>
                    <img src="{{ session.img }}" class="w-3/4 md:w-1/2 rounded-3xl"/>
                    {% if "admin" in app.user.roles %}
                        <a href="{{ url('edit_session', {id: session.id}) }}">Modifier</a>
                        {{ session.isActive }}
                    {% endif %}
                </div>
            </li>
        {% endfor %}
    </ul>

    {% if "admin" in app.user.roles %}
        <button id="add">Ajouter les sessions des deux prochaines semaines</button>
    {% endif %}
</div>

{% block javascripts %}
    {{ importmap('app') }}
    <script type="module">
        import $ from 'jquery';
        $(document).ready(function() {
            //console.log('jQuery est bien chargé !');

            $("#add").click(() => {
                $.get("/sessions/add");
            });
        });
    </script>
{% endblock %}
{% endblock %}
